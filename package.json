{
  "name": "spx-helper",
  "version": "3.5.18",
  "description": "SPX Helper - Shopee大数据开发助手",
  "author": "tianyi.liang",
  "license": "MIT",
  "scripts": {
    "prepare": "bash scripts/setup-hooks.sh",
    "setup": "bash scripts/setup-hooks.sh",
    "verify:hooks": "bash scripts/verify-hooks.sh",
    "push:release": "bash scripts/push-release.sh",
    "finish:release-push": "bash scripts/finish-release-push.sh",
    "lint": "eslint *.js",
    "format": "prettier --write \"**/*.{js,html,css,json,md}\"",
    "build:icons": "node scripts/build-icons.js",
    "verify:cdp": "node scripts/verify-cdp.js",
    "probe:seatalk": "node scripts/probe-seatalk-cdp.js"
  },
  "keywords": [
    "chrome-extension",
    "值班助手",
    "工作辅助",
    "笔记",
    "提醒"
  ],
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2"
  }
}
