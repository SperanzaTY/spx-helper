#!/bin/bash
# pre-push hook — 推送到 release 分支前的检查
# 安装：git config core.hooksPath .githooks
# git 会传入: $1=remote名称  $2=remote URL
#
# 推送策略：
#   推送到 release 分支时，无论目标 remote 是什么，都执行完整检查
#   推送成功后，自动尝试同步到其他 remote（失败不阻塞）

set -e

PUSH_REMOTE="$1"
PUSH_URL="$2"
BRANCH=$(git rev-parse --abbrev-ref HEAD)

# 完全阻止向 main 分支推送 — main 只能通过 MR 从 release 合入
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
  echo ""
  echo "  🛑 禁止直接推送到 ${BRANCH} 分支！"
  echo "  ${BRANCH} 分支只能通过 MR (Merge Request) 从 release 合入。"
  echo ""
  echo "  请在 GitLab 上创建 MR: release → ${BRANCH}"
  echo ""
  exit 1
fi

if [ "$BRANCH" != "release" ]; then
  exit 0
fi

# 以推送目标 remote 作为基准进行检查
PRIMARY_REMOTE="$PUSH_REMOTE"

RELEASE_LOG="docs/RELEASE_LOG.md"
VERSION=$(grep '"version"' chrome-extension/manifest.json | head -1 | sed 's/.*"\([0-9.]*\)".*/\1/')
COMMIT_SHORT=$(git log -1 --format='%h')
COMMIT_MSG=$(git log -1 --format='%s')

echo ""
echo "╔══════════════════════════════════════════════════════════╗"
echo "║  SPX Helper — Release 分支推送检查                      ║"
echo "╠══════════════════════════════════════════════════════════╣"
echo "║  当前版本: v${VERSION}"
echo "║  最新提交: ${COMMIT_SHORT} ${COMMIT_MSG}"
echo "║  推送目标: ${PUSH_REMOTE} (${PUSH_URL})"
echo "╚══════════════════════════════════════════════════════════╝"
echo ""

HAS_ERRORS=0

# 0. 检查 GitLab 远程是否有新提交
echo "🔍 正在检查 ${PRIMARY_REMOTE}/release ..."
git fetch "$PRIMARY_REMOTE" release --quiet 2>/dev/null || true
REMOTE_REF="$PRIMARY_REMOTE/release"
if git rev-parse --verify "$REMOTE_REF" >/dev/null 2>&1; then
  BEHIND=$(git rev-list --count HEAD.."$REMOTE_REF" 2>/dev/null || echo "0")
  if [ "$BEHIND" -gt 0 ]; then
    REMOTE_VER=$(git show "$REMOTE_REF:chrome-extension/manifest.json" 2>/dev/null | grep '"version"' | head -1 | sed 's/.*"\([0-9.]*\)".*/\1/' || echo "?")
    echo "❌ 本地落后于 ${PRIMARY_REMOTE}/release ${BEHIND} 个提交！(远程版本: v${REMOTE_VER})"
    echo "   有人在你开发期间推送了新版本。"
    echo ""
    echo "   请先执行："
    echo "     git pull --rebase ${PRIMARY_REMOTE} release"
    echo "   解决可能的冲突后再推送。"
    echo ""
    HAS_ERRORS=1
  fi
fi
if [ "$HAS_ERRORS" -eq 0 ]; then
  echo "✅ ${PRIMARY_REMOTE}/release 无新提交"
fi

# 1. 检查 RELEASE_LOG 在最新一次提交中是否被修改
if [ -f "$RELEASE_LOG" ]; then
  LOG_CHANGED=$(git diff-tree --no-commit-id --name-only -r HEAD | grep -c "^docs/RELEASE_LOG.md$" || true)
  if [ "$LOG_CHANGED" -eq 0 ]; then
    echo "❌ 发版日志未更新！"
    echo "   本次提交未修改 docs/RELEASE_LOG.md。"
    echo "   每次提交都必须在 RELEASE_LOG.md 中追加记录（包括 docs/chore 类型）。"
    echo ""
    HAS_ERRORS=1
  else
    echo "✅ 发版日志已更新"
  fi
else
  echo "❌ 发版日志文件不存在！"
  echo "   请创建 docs/RELEASE_LOG.md 并记录测试情况。"
  echo ""
  HAS_ERRORS=1
fi

# 2. 检查三个版本号是否一致
V_ROOT=$(grep '"version"' package.json | head -1 | sed 's/.*"\([0-9.]*\)".*/\1/')
V_AGENT=$(grep '"version"' seatalk-agent/package.json | head -1 | sed 's/.*"\([0-9.]*\)".*/\1/')

if [ "$VERSION" != "$V_ROOT" ] || [ "$VERSION" != "$V_AGENT" ]; then
  echo "❌ 版本号不一致！"
  echo "   manifest.json:              ${VERSION}"
  echo "   package.json:               ${V_ROOT}"
  echo "   seatalk-agent/package.json: ${V_AGENT}"
  echo ""
  HAS_ERRORS=1
else
  echo "✅ 版本号一致: v${VERSION}"
fi

# 2.35 本地版本相对 release 不得「跨档」领先（禁止未推送就连续多次改 manifest）
# 规则：与 ${PRIMARY_REMOTE}/release 上的 manifest 相比，只允许
#   - 同 MAJOR.MINOR 时 PATCH 最多 +1（如 3.5.20→3.5.21，禁止直接 3.5.22）
#   - MAJOR 不变时 MINOR 最多 +1（如 3.5.x→3.6.y，禁止 3.5→3.7.0）
#   - MAJOR 最多 +1（如 3.x→4.y.z，禁止 3→5.0.0）
HOOKDIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=lib/version-step.sh
. "$HOOKDIR/lib/version-step.sh"
if ! manifest_version_step_check "$PRIMARY_REMOTE" "$VERSION"; then
  HAS_ERRORS=1
fi

# 2.5 模块 ↔ 文档联动检查
CHANGED_FILES=$(git diff-tree --no-commit-id --name-only -r HEAD)
DOC_ERRORS=0

check_module_doc() {
  local MODULE_NAME="$1"
  local CODE_PATTERN="$2"
  local DOC_PATTERN="$3"
  local DOC_DESC="$4"

  local CODE_CHANGED=$(echo "$CHANGED_FILES" | grep -cE "$CODE_PATTERN" || true)
  if [ "$CODE_CHANGED" -gt 0 ]; then
    local DOC_CHANGED=$(echo "$CHANGED_FILES" | grep -cE "$DOC_PATTERN" || true)
    if [ "$DOC_CHANGED" -eq 0 ]; then
      echo "❌ 修改了 ${MODULE_NAME} 但未更新说明文档！"
      echo "   本次提交修改了 ${CODE_CHANGED} 个 ${MODULE_NAME} 相关文件。"
      echo "   请同步更新: ${DOC_DESC}"
      echo ""
      DOC_ERRORS=1
      HAS_ERRORS=1
    else
      echo "✅ ${MODULE_NAME} 文档已同步"
    fi
  fi
}

check_module_doc \
  "Chrome 扩展" \
  "^chrome-extension/" \
  "^docs/guides/CHROME_EXTENSION\.md$" \
  "docs/guides/CHROME_EXTENSION.md（功能说明、安装步骤）"

check_module_doc \
  "MCP 工具" \
  "^mcp-tools/.*\.(py|json|toml|cfg)$" \
  "^docs/guides/MCP_TOOLS\.md$" \
  "docs/guides/MCP_TOOLS.md（工具说明、配置示例、凭证获取）"

check_module_doc \
  "SeaTalk Agent" \
  "^seatalk-agent/src/" \
  "^docs/guides/SEATALK_AGENT\.md$" \
  "docs/guides/SEATALK_AGENT.md（使用方法、功能说明、注意事项）"

check_module_doc \
  "Cursor Skill" \
  "^\.cursor/skills/" \
  "^docs/guides/SKILL\.md$" \
  "docs/guides/SKILL.md（Skill 列表、依赖 MCP、安装方式）"

# 2.5.1 MCP 子模块 README 联动检查
# 如果修改了 mcp-tools/<tool>/ 下的代码，对应的 mcp-tools/<tool>/README.md 也要更新
MCP_CODE_FILES=$(echo "$CHANGED_FILES" | grep -E "^mcp-tools/[^/]+/.*\.(py|json|toml|cfg)$" || true)
if [ -n "$MCP_CODE_FILES" ]; then
  MCP_MODULES=$(echo "$MCP_CODE_FILES" | sed 's|^mcp-tools/\([^/]*\)/.*|\1|' | sort -u)
  for mod in $MCP_MODULES; do
    README_CHANGED=$(echo "$CHANGED_FILES" | grep -c "^mcp-tools/${mod}/README\.md$" || true)
    if [ "$README_CHANGED" -eq 0 ]; then
      MOD_FILE_COUNT=$(echo "$MCP_CODE_FILES" | grep -c "^mcp-tools/${mod}/" || true)
      echo "❌ 修改了 mcp-tools/${mod}/ 代码（${MOD_FILE_COUNT} 个文件）但未更新模块 README！"
      echo "   请同步更新: mcp-tools/${mod}/README.md"
      echo ""
      DOC_ERRORS=1
      HAS_ERRORS=1
    else
      echo "✅ mcp-tools/${mod}/README.md 已同步"
    fi
  done
fi

if [ "$DOC_ERRORS" -eq 0 ]; then
  MODULE_TOUCHED=$(echo "$CHANGED_FILES" | grep -cE "^(chrome-extension/|mcp-tools/.*\.(py|json|toml|cfg)$|seatalk-agent/src/|\.cursor/skills/)" || true)
  if [ "$MODULE_TOUCHED" -gt 0 ]; then
    echo "✅ 所有模块文档已同步"
  fi
fi

# 2.6 检查 feat/fix 类型提交是否升了版本号（对比 GitLab）
REMOTE_REF="$PRIMARY_REMOTE/release"
if git rev-parse --verify "$REMOTE_REF" >/dev/null 2>&1; then
  REMOTE_VER=$(git show "$REMOTE_REF:chrome-extension/manifest.json" 2>/dev/null | grep '"version"' | head -1 | sed 's/.*"\([0-9.]*\)".*/\1/' || echo "")
  if [ -n "$REMOTE_VER" ] && [ "$REMOTE_VER" = "$VERSION" ]; then
    FEAT_FIX_COUNT=$(git log --oneline "$REMOTE_REF"..HEAD --grep='^feat' --grep='^fix' --extended-regexp 2>/dev/null | wc -l | tr -d ' ')
    if [ "$FEAT_FIX_COUNT" -gt 0 ]; then
      echo "❌ 检测到 feat/fix 类型提交但未升级版本号！"
      echo "   远程版本: v${REMOTE_VER}  →  本地版本: v${VERSION}（未变化）"
      echo "   包含 ${FEAT_FIX_COUNT} 个 feat/fix 提交:"
      git log --oneline "$REMOTE_REF"..HEAD --grep='^feat' --grep='^fix' --extended-regexp 2>/dev/null | sed 's/^/     /'
      echo ""
      echo "   请升级版本号（修改 manifest.json + package.json + seatalk-agent/package.json）"
      echo ""
      HAS_ERRORS=1
    fi
  fi
fi

# 2.7 Agent 功能验证（仅在 seatalk-agent/src/ 有变更时）
AGENT_SRC_CHANGED=$(echo "$CHANGED_FILES" | grep -cE "^seatalk-agent/src/" || true)
if [ "$AGENT_SRC_CHANGED" -gt 0 ]; then
  echo ""
  echo "  Detected SeaTalk Agent code changes (${AGENT_SRC_CHANGED} files), running verification..."
  REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
  CDP_SCRIPT="$REPO_ROOT/scripts/verify-cdp.js"

  if [ ! -f "$CDP_SCRIPT" ]; then
    echo "[FAIL] Verification script not found: scripts/verify-cdp.js"
    HAS_ERRORS=1
  else
    # Try Inspector port (9229) first, fall back to legacy CDP port (19222)
    INSPECTOR_CHECK=$(curl -s -o /dev/null -w "%{http_code}" http://127.0.0.1:9229/json 2>/dev/null || echo "000")
    CDP_CHECK=$(curl -s -o /dev/null -w "%{http_code}" http://127.0.0.1:19222/json 2>/dev/null || echo "000")
    if [ "$INSPECTOR_CHECK" != "200" ] && [ "$CDP_CHECK" != "200" ]; then
      echo "[FAIL] Neither Inspector (9229) nor CDP (19222) is reachable!"
      echo "   Please ensure SeaTalk Agent is running:"
      echo "     cd seatalk-agent && npx tsx src/main.ts"
      echo ""
      HAS_ERRORS=1
    else
      if node "$CDP_SCRIPT"; then
        echo "[OK] Agent verification passed"
      else
        CDP_EXIT=$?
        echo "[FAIL] Agent verification failed (exit code: ${CDP_EXIT})"
        echo "   Run manually: node scripts/verify-cdp.js"
        echo ""
        HAS_ERRORS=1
      fi
    fi
  fi
fi

# 3. Commit message 格式复查（防止 --no-verify 跳过 commit-msg hook）
VALID_TYPES="feat|fix|docs|style|refactor|perf|test|chore|build|ci|revert"
CC_PATTERN="^(${VALID_TYPES})(\([a-zA-Z0-9_-]+\))?\!?:\ .+"
MERGE_PATTERN="^(Merge |Revert |fixup! |squash! |amend! )"

BASE_REF=""
REMOTE_REF="$PRIMARY_REMOTE/release"
if git rev-parse --verify "$REMOTE_REF" >/dev/null 2>&1; then
  BASE_REF="$REMOTE_REF"
fi

if [ -n "$BASE_REF" ]; then
  BAD_COMMITS=""
  while IFS= read -r LINE; do
    HASH=$(echo "$LINE" | cut -d' ' -f1)
    MSG=$(echo "$LINE" | cut -d' ' -f2-)
    if echo "$MSG" | grep -qE "$MERGE_PATTERN"; then
      continue
    fi
    if ! echo "$MSG" | grep -qE "$CC_PATTERN"; then
      BAD_COMMITS="${BAD_COMMITS}\n    ${HASH} ${MSG}"
    fi
  done < <(git log --oneline "$BASE_REF"..HEAD 2>/dev/null)

  if [ -n "$BAD_COMMITS" ]; then
    echo "❌ 以下提交不符合 Conventional Commit 格式："
    echo -e "$BAD_COMMITS"
    echo ""
    echo "   要求格式: <type>: <description>"
    echo "   type: feat / fix / docs / style / refactor / perf / test / chore / build / ci / revert"
    echo ""
    HAS_ERRORS=1
  else
    echo "✅ 所有提交符合 Conventional Commit 格式"
  fi
fi

# 4. 检查发版通知文件是否存在
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
NOTIFICATION_FILE="$REPO_ROOT/.release-notification"
if git ls-files --error-unmatch .release-notification >/dev/null 2>&1; then
  echo "❌ .release-notification 不应被 Git 跟踪！"
  echo "   该文件是一次性 release 通知草稿，只应保留在工作区并受 .gitignore 保护。"
  echo "   请先将它从版本控制中移除，例如："
  echo "     git rm --cached .release-notification"
  echo ""
  HAS_ERRORS=1
fi

if [ ! -f "$NOTIFICATION_FILE" ] || [ ! -s "$NOTIFICATION_FILE" ]; then
  echo "❌ 缺少发版通知文件 .release-notification！"
  echo "   推送成功后会自动发送 SeaTalk 群通知，需要先准备通知内容。"
  echo ""
  echo "   请创建文件（内容为本次发版的自然语言描述）:"
  echo "     echo \"📦 SPX Helper vX.Y.Z 已发布 ...\" > .release-notification"
  echo ""
  echo "   提示：让 AI Agent 提交时自动生成此文件。"
  echo ""
  HAS_ERRORS=1
else
  if ! grep -q "v${VERSION}" "$NOTIFICATION_FILE"; then
    echo "❌ 发版通知内容未包含当前版本号 v${VERSION}！"
    echo "   当前文件可能是旧 release 残留，继续推送会把旧文案发到 SeaTalk。"
    echo "   请更新 .release-notification，确保正文明确提到本次版本号。"
    echo ""
    HAS_ERRORS=1
  else
    echo "✅ 发版通知文件已准备"
  fi
fi

# 5. 提醒：SeaTalk Agent 修改需要重启
AGENT_CHANGED=$(git diff --name-only "$PRIMARY_REMOTE/release"...HEAD 2>/dev/null | grep -c "^seatalk-agent/" || true)
if [ "$AGENT_CHANGED" -gt 0 ]; then
  echo ""
  echo "⚠️  本次推送包含 SeaTalk Agent 修改（${AGENT_CHANGED} 个文件）"
  echo "   提醒：其他团队成员需要重启 Agent 才能生效。"
fi

echo ""

if [ "$HAS_ERRORS" -eq 1 ]; then
  echo "══════════════════════════════════════════════════════════"
  echo "  🛑 推送被阻止！请先修复上述问题。"
  echo "══════════════════════════════════════════════════════════"
  echo ""
  echo "  跳过检查（紧急情况）: git push --no-verify"
  echo ""
  exit 1
fi

echo "✅ 所有检查通过，正在推送..."
echo ""
echo "[release] pre-push 返回时 Git 尚未完成向 GitLab 的传输；GitHub 同步与 SeaTalk 通知应在推送成功之后执行。"
echo "          推荐: npm run push:release"
echo "          若已执行 git push gitlab release: 推送成功后请 npm run finish:release-push"
echo ""
