#!/bin/bash
# pre-push hook — 推送到 release 分支前的检查
# 安装：git config core.hooksPath .githooks

set -e

BRANCH=$(git rev-parse --abbrev-ref HEAD)

# 完全阻止向 main 分支推送 — main 只能通过 MR 从 release 合入
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
  echo ""
  echo "  🛑 禁止直接推送到 ${BRANCH} 分支！"
  echo "  ${BRANCH} 分支只能通过 MR (Merge Request) 从 release 合入。"
  echo ""
  echo "  请在 GitLab 上创建 MR: release → ${BRANCH}"
  echo ""
  exit 1
fi

if [ "$BRANCH" != "release" ]; then
  exit 0
fi

RELEASE_LOG="docs/RELEASE_LOG.md"
VERSION=$(grep '"version"' chrome-extension/manifest.json | head -1 | sed 's/.*"\([0-9.]*\)".*/\1/')
COMMIT_SHORT=$(git log -1 --format='%h')
COMMIT_MSG=$(git log -1 --format='%s')

echo ""
echo "╔══════════════════════════════════════════════════════════╗"
echo "║  SPX Helper — Release 分支推送检查                      ║"
echo "╠══════════════════════════════════════════════════════════╣"
echo "║  当前版本: v${VERSION}"
echo "║  最新提交: ${COMMIT_SHORT} ${COMMIT_MSG}"
echo "╚══════════════════════════════════════════════════════════╝"
echo ""

HAS_ERRORS=0

# 0. 检查远程是否有新提交（防止覆盖他人代码）
echo "🔍 正在检查远程仓库..."
# 尝试 fetch 所有 remote 的 release 分支，静默失败不阻塞
for REMOTE in $(git remote); do
  git fetch "$REMOTE" release --quiet 2>/dev/null || true
done

# 检查本地是否落后于任一 remote
for REMOTE in $(git remote); do
  REMOTE_REF="$REMOTE/release"
  if git rev-parse --verify "$REMOTE_REF" >/dev/null 2>&1; then
    BEHIND=$(git rev-list --count HEAD.."$REMOTE_REF" 2>/dev/null || echo "0")
    if [ "$BEHIND" -gt 0 ]; then
      REMOTE_VER=$(git show "$REMOTE_REF:chrome-extension/manifest.json" 2>/dev/null | grep '"version"' | head -1 | sed 's/.*"\([0-9.]*\)".*/\1/' || echo "?")
      echo "❌ 本地落后于 ${REMOTE}/release ${BEHIND} 个提交！(远程版本: v${REMOTE_VER})"
      echo "   有人在你开发期间推送了新版本。"
      echo ""
      echo "   请先执行："
      echo "     git pull --rebase ${REMOTE} release"
      echo "   解决可能的冲突后再推送。"
      echo ""
      HAS_ERRORS=1
    fi
  fi
done
if [ "$HAS_ERRORS" -eq 0 ]; then
  echo "✅ 远程仓库无新提交"
fi

# 1. 检查 RELEASE_LOG 在最新一次提交中是否被修改
if [ -f "$RELEASE_LOG" ]; then
  LOG_CHANGED=$(git diff-tree --no-commit-id --name-only -r HEAD | grep -c "^docs/RELEASE_LOG.md$" || true)
  if [ "$LOG_CHANGED" -eq 0 ]; then
    echo "❌ 发版日志未更新！"
    echo "   本次提交未修改 docs/RELEASE_LOG.md。"
    echo "   每次提交都必须在 RELEASE_LOG.md 中追加记录（包括 docs/chore 类型）。"
    echo ""
    echo "   请让 Agent 自动生成记录，或手动追加后再推送。"
    echo ""
    HAS_ERRORS=1
  else
    echo "✅ 发版日志已更新"
  fi
else
  echo "❌ 发版日志文件不存在！"
  echo "   请创建 docs/RELEASE_LOG.md 并记录测试情况。"
  echo ""
  HAS_ERRORS=1
fi

# 2. 检查三个版本号是否一致
V_ROOT=$(grep '"version"' package.json | head -1 | sed 's/.*"\([0-9.]*\)".*/\1/')
V_AGENT=$(grep '"version"' seatalk-agent/package.json | head -1 | sed 's/.*"\([0-9.]*\)".*/\1/')

if [ "$VERSION" != "$V_ROOT" ] || [ "$VERSION" != "$V_AGENT" ]; then
  echo "❌ 版本号不一致！"
  echo "   manifest.json:              ${VERSION}"
  echo "   package.json:               ${V_ROOT}"
  echo "   seatalk-agent/package.json: ${V_AGENT}"
  echo ""
  HAS_ERRORS=1
else
  echo "✅ 版本号一致: v${VERSION}"
fi

# 3. 提醒：SeaTalk Agent 修改需要重启
AGENT_CHANGED=$(git diff --name-only origin/release...HEAD 2>/dev/null | grep -c "^seatalk-agent/" || true)
if [ "$AGENT_CHANGED" -gt 0 ]; then
  echo ""
  echo "⚠️  本次推送包含 SeaTalk Agent 修改（${AGENT_CHANGED} 个文件）"
  echo "   提醒：其他团队成员需要重启 Agent 才能生效。"
  echo "   使用 seatalk 命令内的更新功能，或终端运行 seatalk 重启。"
fi

echo ""

if [ "$HAS_ERRORS" -eq 1 ]; then
  echo "══════════════════════════════════════════════════════════"
  echo "  🛑 推送被阻止！请先修复上述问题。"
  echo "══════════════════════════════════════════════════════════"
  echo ""
  echo "  跳过检查（紧急情况）: git push --no-verify"
  echo ""
  exit 1
fi

echo "✅ 所有检查通过，正在推送..."
echo ""
